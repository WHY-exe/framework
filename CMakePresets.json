{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "description": "Target the Windows Subsystem for Linux (WSL) or a remote Linux system.",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "BUILD_UTILS": false,
        "ASSIMP_BUILD_TESTS": false,
        "BUILD_SHARED_LIBS": false
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "description": "Target the Windows Subsystem for Linux (WSL) or a remote Linux system.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "description": "Target the Windows Subsystem for Linux (WSL) or a remote Linux system.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "description": "Target a remote macOS system.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "win-base",
      "inherits": "base",
      "hidden": true,
      "toolchainFile": "${sourceDir}/cmake/Windows.MSVC.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_VS_PLATFORM_TOOLSET_HOST_ARCHITECTURE": "x64",
        "VS_PLATFORM_TOOLSET_VERSION": "14.29.30133",
        "CMAKE_VS_WINDOWS_TARGET_PLATFORM_VERSION": "10.0.22621.0",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true
      }
    },
    {
      "name": "win32-rel",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_SYSTEM_PROCESSOR": "X86",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "win64-rel",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_SYSTEM_PROCESSOR": "AMD64",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "win32-deb",
      "inherits": "win32-rel",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "win64-deb",
      "inherits": "win64-rel",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win32-rel",
      "configurePreset": "win32-rel"
    },
    {
      "name": "win64-rel",
      "configurePreset": "win64-rel"
    },
    {
      "name": "win32-deb",
      "configurePreset": "win32-deb"
    },
    {
      "name": "win64-deb",
      "configurePreset": "win64-deb"
    }
  ]
}